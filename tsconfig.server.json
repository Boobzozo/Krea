{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "outDir": ".",
    "rootDir": ".",
    "noEmit": false,
    "strict": false
  },
  "include": ["server.ts"]
}
