# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted (ex: https://votre-site-krea.com)
APP_URL="https://votre-site-krea.com"

# Google OAuth Credentials for Calendar Integration
GOOGLE_CLIENT_ID="votre-id-google.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="votre-secret-google"

# Email Confirmation (Resend API)
RESEND_API_KEY="re_votre_cle_resend"

# n8n Automation Webhook
N8N_WEBHOOK_URL="https://votre-n8n.webhook.url"

# Session Secret (Choose a long random string)
SESSION_SECRET="choisissez_un_secret_long_et_aleatoire"

# Node Environment (set to production on Hostinger)
NODE_ENV="production"
